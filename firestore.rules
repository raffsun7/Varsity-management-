rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['admin', 'teacher', 'student'] &&
             data.createdAt == request.time;
    }

    function isValidSuggestion(data) {
      return data.keys().hasAll(['title', 'content', 'type', 'createdBy', 'status', 'timestamp']) &&
             data.keys().size() <= 8 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.type in ['notice', 'lecture', 'note'] &&
             data.createdBy == request.auth.uid &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.timestamp == request.time;
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'message', 'priority', 'audience', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 5000 &&
             data.priority in ['low', 'normal', 'urgent'] &&
             data.audience is string && data.createdAt == request.time;
    }

    function isValidLecture(data) {
      return data.keys().hasAll(['courseName', 'title', 'week', 'createdAt']) &&
             data.courseName is string && data.title is string &&
             data.week is int && data.createdAt == request.time;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'fileUrl', 'courseName', 'uploadedBy', 'createdAt']) &&
             data.title is string && data.fileUrl is string &&
             data.courseName is string && data.uploadedBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidNotification(data) {
       return data.keys().hasAll(['title', 'message', 'userId', 'isRead', 'createdAt', 'type']) &&
              data.userId is string && data.isRead is bool && data.createdAt == request.time;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming()) && (incoming().role == 'student' || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'department']));
    }

    match /suggestions/{id} {
      allow read: if isSignedIn() && (isAdmin() || existing().createdBy == request.auth.uid);
      allow create: if isSignedIn() && isValidSuggestion(incoming()) && incoming().status == 'pending';
      allow update: if isSignedIn() && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'feedback'])) ||
        (isOwner(existing().createdBy) && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'type', 'timestamp']) && isValidSuggestion(incoming()))
      );
      allow delete: if isAdmin() || (isOwner(existing().createdBy) && existing().status == 'pending');
    }

    match /notices/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /lectures/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notes/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && (
        existing().userId == request.auth.uid || 
        (existing().userId == 'student_all' && !isAdmin()) || 
        (existing().userId == 'admin_all' && isAdmin())
      );
      allow create: if isSignedIn() && (
        isAdmin() || 
        (incoming().userId == 'admin_all' && incoming().type == 'new_suggestion')
      );
      allow update: if isSignedIn() && (
        existing().userId == request.auth.uid || 
        (existing().userId == 'student_all' && !isAdmin()) || 
        (existing().userId == 'admin_all' && isAdmin())
      ) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin() || existing().userId == request.auth.uid;
    }
  }
}
